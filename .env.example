# LLM / embedding service. LLM_* is preferred; ARK_* remains a legacy alias.
LLM_API_KEY=replace-with-your-api-key
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash
# One SDK attempt is bounded by phase timeouts; all attempts share the total budget.
LLM_CONNECT_TIMEOUT_SECONDS=10
LLM_READ_TIMEOUT_SECONDS=540
LLM_WRITE_TIMEOUT_SECONDS=30
LLM_POOL_TIMEOUT_SECONDS=10
LLM_TOTAL_TIMEOUT_SECONDS=570
LLM_MAX_ATTEMPTS=3
LLM_RETRY_DELAY_SECONDS=2
# Per LangGraph execution superstep; keep this above LLM_TOTAL_TIMEOUT_SECONDS.
NODE_EXECUTION_TIMEOUT_SECONDS=600
ARK_API_KEY=replace-with-your-api-key
ARK_BASE_URL=https://api.siliconflow.cn/v1

# External research. Configure the selected provider.
SEARCH_API=tavily
MAX_WEB_RESEARCH_LOOPS=2
MAX_RESEARCH_TASKS=3
MAX_TOTAL_SEARCHES=6
TAVILY_API_KEY=replace-with-your-tavily-key
PERPLEXITY_API_KEY=
SEARXNG_URL=http://localhost:8888
FETCH_FULL_PAGE=false
MAX_RESULTS_PER_SEARCH=3
# CLI 和未显式指定请求的默认值；Web 请求可传 0 表示不限时
RESEARCH_TOTAL_TIMEOUT_SECONDS=120

# Pilot runtime. Browser users sign in with configured accounts and receive an HttpOnly session cookie.
APP_ENV=production
AUTH_ENABLED=true
AUTH_SESSION_SECRET=replace-with-at-least-32-random-characters
AUTH_SESSION_TTL_SECONDS=28800
AUTH_SESSION_SECURE=false
# Unified account configuration. Production should replace password with a password_hash generated by: python security.py
AUTH_USERS_JSON={"admin":{"display_name":"系统管理员","password":"replace-with-strong-password","subject":"admin-1","role":"admin","tenant_id":"factory-a"},"operator":{"display_name":"诊断操作员","password":"replace-with-another-password","subject":"operator-1","role":"operator","tenant_id":"factory-a"}}
# Alternatively store the same JSON in a protected file:
# AUTH_USERS_FILE=config/auth-users.json
# Optional machine-to-machine compatibility only; never expose these credentials in the Web page.
PILOT_API_KEY=
# API_KEYS_JSON={"integration-secret":{"subject":"cmms-service","role":"operator","tenant_id":"factory-a"}}
CHECKPOINT_BACKEND=sqlite
CHECKPOINT_SQLITE_PATH=output/runtime/checkpoints.sqlite3
PILOT_DB_PATH=output/runtime/pilot.sqlite3
SESSION_TTL_SECONDS=86400
MAX_CONCURRENT_DIAGNOSES=2
RATE_LIMIT_PER_MINUTE=60
MERMAID_VALIDATION_TIMEOUT_SECONDS=8
MERMAID_VALIDATOR_STARTUP_TIMEOUT_SECONDS=25

# P1 managed knowledge and artifact export.
KNOWLEDGE_MAX_UPLOAD_BYTES=15728640
KNOWLEDGE_MAX_EXTRACTED_CHARS=2000000
# Uploaded originals are retained here; SQLite remains the document/version source of truth.
KNOWLEDGE_FILES_DIR=output/knowledge
# Current active chunks are embedded and synchronized to this Milvus collection.
MANAGED_KNOWLEDGE_VECTOR_ENABLED=true
MANAGED_KNOWLEDGE_COLLECTION=managed_sop_knowledge
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_DIM=2560
EMBEDDING_BATCH_SIZE=16
EMBEDDING_TIMEOUT_SECONDS=60
# Optional token pricing used only by the quality/cost dashboard.
LLM_INPUT_COST_PER_1M=0
LLM_OUTPUT_COST_PER_1M=0
# Optional custom CJK TrueType/OpenType font path for PDF export.
# PDF_CJK_FONT=C:/Windows/Fonts/msyh.ttc

# Legacy misspelled alias; do not use for new deployments.
# trivily_key=replace-with-your-tavily-key

# Option A: self-hosted Milvus.
# MILVUS_HOST=127.0.0.1
# MILVUS_PORT=19530
# MILVUS_USER=root
# MILVUS_PASSWORD=

# Option B: Zilliz Cloud / remote Milvus.
# URL=https://your-zilliz-or-milvus-uri
# Token=replace-with-your-token

# If neither Milvus option is configured, the app uses local milvus-lite at:
# output/milvus_local.db

# Optional Langfuse tracing.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=
